# 阶段二外部依赖（PHASE2-PLAN §0 / 00-overview §1.4）。
# 用法：复制本文件为 .env（已被 .gitignore 忽略），填入真实值。
# 优先级：① Neon 解锁最多（① 接真验证 + ② 鉴权 + ③ 钱链路命门测试）；② 存储（putToR2 往返 + ④ 落图）；其余按阶段补。

# ───────── 优先级 1 · Neon Postgres（解锁 ①接真 + ②③ 全部钱链路）─────────
# 在 https://neon.tech 建项目（region 选 AWS US East / us-east-1，与 Netlify 函数同区）。
# 在 Dashboard → Connection Details 复制两条串：
#   - Pooled（带 -pooler 的 host）→ DATABASE_URL        （看板/单语句/HTTP）
#   - Direct（不带 -pooler）     → DATABASE_URL_UNPOOLED （钱/码事务 + FOR UPDATE，命门）
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# ───────── 优先级 2 · 对象存储（S3 兼容；putToR2 往返 + ④ 落图）─────────
# 后端 = Supabase Storage（免自定义域/免绑卡，公有桶自带公开 URL）。厂商中立 STORAGE_*，换 R2/B2/S3 只改值。
# Supabase → 建 project → Storage 建 **Public** 桶 → Project Settings → Storage 看 S3 Connection（endpoint/region）+ 建 S3 Access Keys。
STORAGE_S3_ENDPOINT=          # Supabase: https://<ref>.storage.supabase.co/storage/v1/s3
STORAGE_S3_REGION=            # Supabase 项目 region，如 us-east-1（R2 用 auto）
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
STORAGE_BUCKET=              # 桶名，如 images
STORAGE_PUBLIC_BASE_URL=     # 公有桶公开前缀，如 https://<ref>.supabase.co/storage/v1/object/public/images（结尾不带 /）

# ───────── ② 鉴权 · Better Auth ─────────
# BETTER_AUTH_SECRET 我可帮你生成（openssl rand -base64 32 等价物）；BETTER_AUTH_URL 填站点 URL（本地 http://localhost:8888）。
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:8888

# ───────── ④ 生图管线 · 中转（v1 已有，确认沿用）─────────
RELAY_API_KEY=
RELAY_BASE_URL=https://api.tangguo.xin/v1
# RELAY_BASE_URL_BACKUP=   # 可选备用 Base
# 预算熔断阈值（铁律①；GB-hour 实测对账后调准，seed 默认 calls=2000 / ms=600000000）
# DAILY_RELAY_BUDGET_CALLS=2000
# DAILY_RELAY_BUDGET_MS=600000000

# ───────── 种子 / 运维（可选）─────────
# SEED_ADMIN_EMAIL=        # 注册建号后，seed 把此邮箱提权为 admin
# SENTRY_DSN=
# ADMIN_ALERT_WEBHOOK=
