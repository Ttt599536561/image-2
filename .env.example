# 本地开发变量模板。Debian 生产部署使用 deploy/.env.production.example。
# 用法：复制本文件为 .env（已被 .gitignore 忽略），只填非生产或本地所需值。

# ───────── PostgreSQL（当前托管方案为 Neon）─────────
# 区域优先选择靠近 Debian 主机与主要用户的位置。
# 在 Dashboard → Connection Details 复制两条串：
#   - Pooled（带 -pooler 的 host）→ DATABASE_URL        （看板/单语句/HTTP）
#   - Direct（不带 -pooler）     → DATABASE_URL_UNPOOLED （钱/码事务 + FOR UPDATE，命门）
# Node pg 连接串显式使用 sslmode=verify-full，避免未来主版本弱化 require 的兼容语义。
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# ───────── 优先级 2 · 对象存储（S3 兼容；putToR2 往返 + ④ 落图）─────────
# 后端 = Supabase Storage（免自定义域/免绑卡，公有桶自带公开 URL）。厂商中立 STORAGE_*，换 R2/B2/S3 只改值。
# Supabase → 建 project → Storage 建 **Public** 桶 → Project Settings → Storage 看 S3 Connection（endpoint/region）+ 建 S3 Access Keys。
STORAGE_S3_ENDPOINT=          # Supabase: https://<ref>.storage.supabase.co/storage/v1/s3
STORAGE_S3_REGION=            # Supabase 项目 region，如 us-east-1（R2 用 auto）
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
STORAGE_BUCKET=              # 桶名，如 images
STORAGE_PUBLIC_BASE_URL=     # 公有桶公开前缀，如 https://<ref>.supabase.co/storage/v1/object/public/images（结尾不带 /）

# ───────── ② 鉴权 · Better Auth ─────────
# BETTER_AUTH_SECRET 我可帮你生成（openssl rand -base64 32 等价物）；BETTER_AUTH_URL 填站点 URL（本地 http://localhost:8888）。
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:8888
TRUST_PROXY=false
WORKER_CONCURRENCY=1

# ───────── ④ 生图管线 · 中转（v1 已有，确认沿用）─────────
RELAY_API_KEY=
RELAY_BASE_URL=https://api.tangguo.xin/v1
# RELAY_BASE_URL_BACKUP=   # 可选备用 Base
# 32-byte canonical base64 or unpadded base64url key for custom API key AES-256-GCM.
CUSTOM_KEY_JOB_ENCRYPTION_KEY=
# Local/manual config is fail-closed; Debian deploy/install.sh explicitly writes true.
# Missing/false remains the operational kill switch for custom submissions.
CUSTOM_KEY_MODES_ENABLED=false
# system relay 预算熔断阈值；按真实调用成本与吞吐调准。
# DAILY_RELAY_BUDGET_CALLS=2000
# DAILY_RELAY_BUDGET_MS=600000000

# ───────── 种子 / 运维（可选）─────────
# SEED_ADMIN_EMAIL=        # 注册建号后，seed 把此邮箱提权为 admin
# SENTRY_DSN=
# ADMIN_ALERT_WEBHOOK=

# Destructive money/migration tests MUST use a separate gitignored .env.test.
# .env.test must contain DATABASE_URL, DATABASE_URL_UNPOOLED and:
# MONEY_TEST_ALLOW_MUTATION=I_UNDERSTAND_THIS_IS_A_DISPOSABLE_DATABASE
# Local E2E also needs BETTER_AUTH_URL/BETTER_AUTH_SECRET, a test-only
# CUSTOM_KEY_JOB_ENCRYPTION_KEY, and CUSTOM_KEY_MODES_ENABLED=true.
