COMPOSE_PROJECT_NAME=ai-image-workshop
COMPOSE_PROFILES=caddy
IMAGE_TAG=latest
DOMAIN=example.com
WEB_BIND_ADDRESS=127.0.0.1
WEB_HOST_PORT=18080
POSTGRES_DB=ai_image_workshop
POSTGRES_USER=ai_image_workshop
POSTGRES_PASSWORD=example-only-change-me
DATABASE_DRIVER=pg
DATABASE_URL=postgresql://ai_image_workshop:example-only-change-me@postgres:5432/ai_image_workshop
DATABASE_URL_UNPOOLED=postgresql://ai_image_workshop:example-only-change-me@postgres:5432/ai_image_workshop
STORAGE_DRIVER=local
LOCAL_STORAGE_ROOT=/app/data/media
BETTER_AUTH_SECRET=replace-with-a-generated-auth-secret
BETTER_AUTH_URL=https://example.com
RELAY_API_KEY=replace-with-your-relay-key
RELAY_BASE_URL=https://api.tangguo.xin/v1
CUSTOM_KEY_JOB_ENCRYPTION_KEY=replace-with-a-generated-encryption-key
CUSTOM_KEY_MODES_ENABLED=false
WORKER_CONCURRENCY=1
TRUST_PROXY=true
