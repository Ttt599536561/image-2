{
  "name": "ai-image-workshop",
  "version": "0.2.1",
  "private": true,
  "engines": {
    "node": ">=22 <23"
  },
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "start:worker": "node --import tsx scripts/worker.ts",
    "start:scheduler": "node --import tsx scripts/scheduler.ts",
    "start:web": "react-router-serve ./build/server/index.js",
    "db:migrate:production": "node --import tsx scripts/migrate-production.ts",
    "dev:disposable:test": "node --import tsx scripts/run-disposable-test.ts",
    "dev:ui:test": "node --import tsx scripts/run-ui-test.ts",
    "build": "react-router build",
    "typecheck": "react-router typegen && tsc",
    "test": "vitest",
    "test:run": "vitest run",
    "test:money": "vitest run -c vitest.money.config.ts",
    "test:e2e": "node --import tsx scripts/run-playwright-test.ts",
    "db:test:migrate": "node --import tsx scripts/migrate-test-database.ts",
    "assert-no-secrets": "node --env-file-if-exists=.env --import tsx scripts/assert-no-secrets-in-bundle.ts",
    "docker:validate": "docker compose --env-file deploy/.env.production.example config --quiet",
    "test:deploy": "bash deploy/install-lib.test.sh && bash deploy/install.test.sh && bash deploy/auth-migration.test.sh && bash deploy/backup-restore.test.sh && bash deploy/ci-smoke.test.sh",
    "release:validate": "node --import tsx scripts/validate-release.ts",
    "test:deploy:smoke": "bash deploy/ci-smoke.sh"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1073.0",
    "@neondatabase/serverless": "^1.1.0",
    "@react-router/node": "8.0.1",
    "@react-router/serve": "^8.0.1",
    "@tanstack/react-query": "^5.66.0",
    "bcryptjs": "3.0.3",
    "better-auth": "1.6.20",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "isbot": "^5.1.0",
    "lucide-react": "1.14.0",
    "pg": "8.22.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "8.0.1",
    "semver": "7.8.5",
    "tsx": "^4.22.4",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@react-router/dev": "8.0.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/bcryptjs": "2.4.6",
    "@types/node": "25.6.2",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/semver": "7.7.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "6.0.1",
    "dotenv": "17.4.2",
    "drizzle-kit": "^0.31.10",
    "jsdom": "29.1.1",
    "pg-connection-string": "2.14.0",
    "toml": "^3.0.0",
    "typescript": "6.0.3",
    "vite": "8.1.4",
    "vitest": "4.1.5"
  }
}
